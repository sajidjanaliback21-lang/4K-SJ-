rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      // Security removed as per user request to use simple password only
      return true;
    }

    // Settings Collection
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Free Movies Collection
    match /free_movies/{movieId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Free Series Collection
    match /free_series/{seriesId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
